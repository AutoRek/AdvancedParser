	<Sequence Name='28E'>
		<Symbol>:28E:</Symbol>
		<Symbol>5n/4!c\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='35B'>
		<Symbol>:35B:</Symbol>
		<Symbol>[ISIN1!e12!c]\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='35B'>
		<Symbol>:35B:</Symbol>
		<Symbol>[ISIN1!e12!c]\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='36B'>
		<Symbol>:36B:</Symbol>
		<Symbol>:4!c//4!c/15d\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='36B'>
		<Symbol>:36B:</Symbol>
		<Symbol>:4!c//4!c/15d\r\n\s*</Symbol>
	</Sequence>

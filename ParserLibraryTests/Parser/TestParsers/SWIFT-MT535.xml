<!--
MT535 Inner Parser
==================
Parses the section 4 of an SWIFT MT535
-->
<Rules>
	<DateTimeFormat>
		<ShortDatePattern>yyyyMMdd</ShortDatePattern>
	</DateTimeFormat>

	<Sequence Record="Message">
		<Include>BasicHeader</Include>
		<Include>ApplicationHeader</Include>
		<Optional>
			<Include>UserHeader</Include>
		</Optional>
		<Include>TextBlock</Include>
		<Optional>
			<Include>TrailerBlock</Include>
		</Optional>
	</Sequence>

	<Sequence Name="BasicHeader">
		<Symbol>\{1:</Symbol>
		<Symbol Field="AppIdent"    >F|A|L</Symbol>
		<Symbol Field="ServiceId"   >\d{2}</Symbol>
		<Symbol Field="LTIdent"     >\w{12}</Symbol>
		<Symbol Field="SessionNbr"  >\d{4}</Symbol>
		<Symbol Field="SequenceNbr" >\d{6}</Symbol>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="ApplicationHeader">
		<Symbol>\{2:</Symbol>
		<Choice>
			<Include>InputHeader</Include>
			<Include>OutputHeader</Include>
		</Choice>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="UserHeader">
		<Symbol>\{3:</Symbol>
		<Include>CustomTags</Include>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="TextBlock">
		<Symbol>\{4:\s*</Symbol>
		<Include>MT535</Include>
		<Symbol>-\}\s*</Symbol>
	</Sequence>

	<Sequence Name="TrailerBlock">
		<Symbol>\{5:</Symbol>
		<Include>CustomTags</Include>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="InputHeader">
		<Symbol Field="InOut">I</Symbol>
		<Symbol Field="MessageType">\d{3}</Symbol>
		<Symbol Field="Receiver">\w{12}</Symbol>
		<Symbol Field="Priority">(S\d\d\d\d)|(U\d\d\d\d)|N</Symbol>
	</Sequence>

	<Sequence Name="OutputHeader">
		<Symbol>O</Symbol>
		<Symbol>\d{3}</Symbol>
		<Symbol>\d{4}</Symbol>
		<Symbol>\w{28}</Symbol>
		<Symbol>\d{6}</Symbol>
		<Symbol>\d{4}</Symbol>
		<Symbol>S|U|N</Symbol>
	</Sequence>

	<OneOrMore Name="CustomTags">
		<Sequence>
			<Symbol>\{</Symbol>
			<Symbol>\w+</Symbol>
			<Symbol>:</Symbol>
			<Symbol>.*?(?=\})</Symbol>
			<Symbol>\}\s*</Symbol>
		</Sequence>
	</OneOrMore>

	<Sequence Name="MT535">
		<Include>SequenceA</Include>
		<!--<OneOrMore>-->
			<Include>SequenceB</Include>
		<!--</OneOrMore>-->
		<Include>SequenceC</Include>
	</Sequence>

	<Sequence Name="SequenceA" Record="SequenceA">
		<Include>16R-GENL</Include>
		<Include>28E</Include>
		<Optional>
			<Include>13aStatementNumber</Include>
		</Optional>
		<Include>20C</Include>
		<Include>23G</Include>
		<OneOrMore>
			<Choice>
				<Include>98A</Include>
				<Include>98C</Include>
				<Include>98E</Include>
			</Choice>
		</OneOrMore>
		<OneOrMore>
			<Include>22F</Include>
		</OneOrMore>
		<Optional>
			<OneOrMore>
				<Include>SequenceA1</Include>
			</OneOrMore>
		</Optional>
		<Optional>
			<Include>95a</Include>
		</Optional>
		<Include>97a</Include>
		<OneOrMore>
			<Include>17B</Include>
		</OneOrMore>
		<Include>16S-GENL</Include>
	</Sequence>

	<Sequence Name="SequenceA1" Record="SequenceA1">
		<Include>16R-LINK</Include>
		<Optional>
			<Include>13aLinkedMessage</Include>
		</Optional>
		<Include>20C</Include>
		<Include>16S-LINK</Include>
	</Sequence>

	<Sequence Name="SequenceB" Record="SequenceB">
		<If Pattern=":16R:SUBSAFE">
			<OneOrMore>
				<Sequence>
					<Include>16R-SUBSAFE</Include>
					<Include>MISC</Include>
					<Include>MISC</Include>
					<Include>SequenceB1</Include>
					<Optional>
						<Include>MISC</Include>
					</Optional>
					<Include>16S-SUBSAFE</Include>
				</Sequence>
			</OneOrMore>
		</If>
	</Sequence>

	<Sequence Name="SequenceB1">
		<If Pattern=":16R:FIN">
			<OneOrMore>
				<Sequence>
					<Include>16R-FIN</Include>
					<Include>MISC</Include>
					<Include>MISC</Include>
					<Include>MISC</Include>
					<Include>MISC</Include>
					<Include>SequenceB1b</Include>
					<Include>Breakdown</Include>
					<Optional>
						<Include>MISC</Include>
					</Optional>
					<Include>16S-FIN</Include>
				</Sequence>
			</OneOrMore>
		</If>
	</Sequence>

	<Sequence Name="SequenceB1b">
		<If Pattern=":16R:SUBBAL">
			<OneOrMore>
				<Sequence>
					<Include>16R-SUBBAL</Include>
					<Include>MISC</Include>
					<Include>MISC</Include>
					<Include>MISC</Include>
					<Include>Breakdown</Include>
					<Include>16S-SUBBAL</Include>
				</Sequence>
			</OneOrMore>
		</If>
	</Sequence>

	<Sequence Name="SequenceC"  Record="SequenceC">
		<If Pattern=":16R:ADDINFO">
			<OneOrMore>
				<Sequence>
					<Include>16R-ADDINFO</Include>
					<Optional>
						<Include>95a</Include>
					</Optional>
					<Optional>
						<Include>19A</Include>
					</Optional>
					<Include>16S-ADDINFO</Include>
				</Sequence>
			</OneOrMore>
		</If>
	</Sequence>

	<Sequence Name="Breakdown">
		<If Pattern=":16R:BREAK">
			<OneOrMore>
				<Sequence>
					<Include>16R-BREAK</Include>
					<Include>MISC</Include>
					<Include>16S-BREAK</Include>
				</Sequence>
			</OneOrMore>
		</If>
	</Sequence>

	<Sequence Name="MISC">
		<Symbol>:\w+:(?&lt;!:16S:)</Symbol>
		<Symbol>(?ms).*?\r\n(?=:)</Symbol>
	</Sequence>

	<Sequence Name='13aStatementNumber'>
		<Symbol>:13(A|J)::\s*STAT//</Symbol>
		<Choice>
			<Sequence>
				<Symbol Field='Statement Number'>\w{5}</Symbol>
			</Sequence>
			<Sequence>
				<Symbol Field='Statement Number'>\w{3}</Symbol>
			</Sequence>
		</Choice>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>
	<Sequence Name='13aLinkedMessage'>
		<Symbol>:13(A|B)::\s*LINK</Symbol>
		<Choice>
			<Sequence>
				<Symbol>//</Symbol>
				<Symbol Field='###'>\w{3}</Symbol>
			</Sequence>
			<Sequence>
				<Symbol>/</Symbol>
				<Symbol Field='###'>(?ms)\w{1,8}/.{1,30}?(?=\s*^:)</Symbol>
			</Sequence>
		</Choice>
	</Sequence>
	<Sequence Name='13aGeneric'>
		<Choice>
			<Sequence>
				<Symbol>LOTS</Symbol>
				<Choice>
					<Sequence>
						<Symbol Field='NumberId/Quantity'>\w{3}/\d{1,15}</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>//</Symbol>
						<Symbol Field='NumberId'>\w{3}</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>/</Symbol>
						<Symbol Field='DataSourceScheme/Number'>(?ms)\w{1,8}/.{1,30}?(?=\s*^:)</Symbol>
					</Sequence>
				</Choice>
			</Sequence>
			<Sequence>
				<Symbol>POOL|COUP</Symbol>
				<Choice>
					<Sequence>
						<Symbol>//</Symbol>
						<Symbol Field='NumberId'>\w{3}</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>/</Symbol>
						<Symbol Field='DataSourceScheme/Number'>(?ms)\w{1,8}/.{1,30}?(?=\s*^:)</Symbol>
					</Sequence>
				</Choice>
			</Sequence>
		</Choice>
	</Sequence>
	<Sequence Name='13aLotNumber'>
		<Symbol>:13(A|B)::\s*LOTS//</Symbol>
		<Choice>
			<Sequence>
				<Symbol>//</Symbol>
				<Symbol Field='Lot Number'>\w{3}</Symbol>
			</Sequence>
			<Sequence>
				<Symbol>/</Symbol>
				<Symbol Field='Lot Number'>(?ms)\w{1,8}/.{1,30}?(?=\s*^:)</Symbol>
			</Sequence>
		</Choice>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>
	<Sequence Name='16R-ADDINFO'>
		<Symbol>:16R:ADDINFO\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16R-SUBSAFE'>
		<Symbol>:16R:SUBSAFE\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16R-SUBBAL'>
		<Symbol>:16R:SUBBAL\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16R-BREAK'>
		<Symbol>:16R:BREAK\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16R-GENL'>
		<Symbol>:16R:GENL\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16R-LINK'>
		<Symbol>:16R:LINK\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16R-FIN'>
		<Symbol>:16R:FIN\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16R-FIA'>
		<Symbol>:16R:FIA\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16S-ADDINFO'>
		<Symbol>:16S:ADDINFO\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16S-SUBSAFE'>
		<Symbol>:16S:SUBSAFE\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16S-SUBBAL'>
		<Symbol>:16S:SUBBAL\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16S-BREAK'>
		<Symbol>:16S:BREAK\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16S-GENL'>
		<Symbol>:16S:GENL\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16S-LINK'>
		<Symbol>:16S:LINK\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16S-FIN'>
		<Symbol>:16S:FIN\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name='16S-FIA'>
		<Symbol>:16S:FIA\r\n\s*</Symbol>
	</Sequence>
	<Sequence Name="17B">
		<Symbol>:17B::</Symbol>
		<Choice>
			<Sequence>
				<Symbol>ACTI//</Symbol>
				<Symbol Field="Activity Flag">Y|N</Symbol>
			</Sequence>
			<Sequence>
				<Symbol>AUDT//</Symbol>
				<Symbol Field="Audited Statement">Y|N</Symbol>
			</Sequence>
			<Sequence>
				<Symbol>CONS//</Symbol>
				<Symbol Field="Sub-safekeeping Statement">Y|N</Symbol>
			</Sequence>
			<Sequence>
				<Symbol>LOTS//</Symbol>
				<Symbol Field="Tax Lots">Y|N</Symbol>
			</Sequence>
		</Choice>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>
	<Sequence Name="19A">
		<Symbol>:19A::\s*</Symbol>
		<Choice>
			<Sequence>
				<Symbol>HOLP//</Symbol>
				<Symbol Field="Total Value of Holdings of Page">(\+|-|)?\w{3}\d{1,15}</Symbol>
			</Sequence>
			<Sequence>
				<Symbol>HOLS//</Symbol>
				<Symbol Field="Total Holdings Value of Statement">(\+|-|)?\w{3}\d{1,15}</Symbol>
			</Sequence>
			<Sequence>
				<Symbol>TOVA//</Symbol>
				<Symbol Field="Total Eligible Collateral Value">(\+|-|)?\w{3}\d{1,15}</Symbol>
			</Sequence>
		</Choice>
		<Symbol>\s*?(?=:)</Symbol>
	</Sequence>
	<Sequence Name='20C'>
		<Symbol>:20C::</Symbol>
		<Choice>
			<Sequence>
				<Symbol>SEME</Symbol>
				<Symbol>//</Symbol>
				<Symbol Field='Senders Message Reference'>(?ms).{1,16}?(?=\s*^:)</Symbol>
			</Sequence>
			<Sequence>
				<Symbol>PREV</Symbol>
				<Symbol>//</Symbol>
				<Symbol Field='Previous Message Reference'>(?ms).{1,16}?(?=\s*^:)</Symbol>
			</Sequence>
			<Sequence>
				<Symbol>RELA</Symbol>
				<Symbol>//</Symbol>
				<Symbol Field='Related Message Reference'>(?ms).{1,16}?(?=\s*^:)</Symbol>
			</Sequence>
		</Choice>
		<Symbol>\s*?(?=:)</Symbol>
	</Sequence>
	<Sequence Name="22F">
		<Symbol>:22F::\s*</Symbol>
		<Choice>
			<Sequence>
				<Symbol>SFRE</Symbol>
				<Choice>
					<Sequence>
						<Symbol>//</Symbol>
						<Symbol Field="Statement Frequency Indicator">ADHO|DAIL|INDA|MNTH|WEEK|YEAR</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>/</Symbol>
						<Symbol Field="Statement Data Source Scheme">\w{1,8}</Symbol>
						<Symbol>/</Symbol>
						<Symbol Field="Statement Frequency Indicator">\w{4}</Symbol>
					</Sequence>
				</Choice>
			</Sequence>
			<Sequence>
				<Symbol>CODE</Symbol>
				<Choice>
					<Sequence>
						<Symbol>//</Symbol>
						<Symbol Field="CompleteOrUpdates Indicator">COMP|DELT</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>/</Symbol>
						<Symbol Field="CompleteOrUpdates Data Source Scheme">\w{1,8}</Symbol>
						<Symbol>/</Symbol>
						<Symbol Field="CompleteOrUpdates Indicator">\w{4}</Symbol>
					</Sequence>
				</Choice>
			</Sequence>
			<Sequence>
				<Symbol>STTY</Symbol>
				<Choice>
					<Sequence>
						<Symbol>//</Symbol>
						<Symbol Field="Statement Type">ACCT|CUST</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>/</Symbol>
						<Symbol Field="Statement Type Data Source Scheme">\w{1,8}</Symbol>
						<Symbol>/</Symbol>
						<Symbol Field="Statement Type">\w{4}</Symbol>
					</Sequence>
				</Choice>
			</Sequence>
			<Sequence>
				<Symbol>STBA</Symbol>
				<Choice>
					<Sequence>
						<Symbol>//</Symbol>
						<Symbol Field="Statement Basis">CONT|SETT|TRAD</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>/</Symbol>
						<Symbol Field="Statement Basis Data Source Scheme">\w{1,8}</Symbol>
						<Symbol>/</Symbol>
						<Symbol Field="Statement Basis">\w{4}</Symbol>
					</Sequence>
				</Choice>
			</Sequence>
		</Choice>
		<Symbol>\s*?(?=:)</Symbol>
	</Sequence>
	<Sequence Name='23G'>
		<Symbol>:23G:</Symbol>
		<Symbol Field='Message Function'>NEWM|CANC</Symbol>
		<Optional>
			<Sequence>
				<Symbol>/</Symbol>
				<Symbol Field='Message SubFunction'>CODU|COPY|DUPL</Symbol>
			</Sequence>
		</Optional>
		<Symbol>\s*?(?=:)</Symbol>
	</Sequence>
	<Sequence Name="28E">
		<Symbol>:28E:</Symbol>
		<Symbol Field="PageNumber">\d{1,5}</Symbol>
		<Symbol>/</Symbol>
		<Symbol Field="ContinuationIndicator">[a-zA-Z]{4}</Symbol>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>
	<Sequence Name="95a">
		<Choice>
			<Sequence>
				<Symbol>:95P::\s*</Symbol>
				<Choice>
					<Sequence>
						<Symbol>ACOW//</Symbol>
						<Symbol Field="Account Owner Identifier Code">(?ms)(\w{11}|\w{8})(?=\s*^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>MEOR//</Symbol>
						<Symbol Field="Originator of Message Identifier Code">(?ms)(\w{11}|\w{8})(?=\s*^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>MERE//</Symbol>
						<Symbol Field="Recipient of Message Identifier Code">(?ms)(\w{11}|\w{8})(?=\s*^:)</Symbol>
					</Sequence>
				</Choice>
			</Sequence>
			<Sequence>
				<Symbol>:95R::</Symbol>
				<Choice>
					<Sequence>
						<Symbol>ACOW/</Symbol>
						<Symbol Field="Account Owner Data Source Scheme">\w{1,8}</Symbol>
						<Symbol>/</Symbol>
						<Symbol Field="Account Owner Proprietary Code">(?ms).{1,34}?(?=\s*^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>MEOR/</Symbol>
						<Symbol Field="Originator of Message Data Source Scheme">\w{1,8}</Symbol>
						<Symbol>/</Symbol>
						<Symbol Field="Originator of Message Proprietary Code">(?ms).{1,34}?(?=\s*^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>MERE/</Symbol>
						<Symbol Field="Recipient of Message Data Source Scheme">\w{1,8}</Symbol>
						<Symbol>/</Symbol>
						<Symbol Field="Recipient of Message Proprietary Code">(?ms).{1,34}?(?=\s*^:)</Symbol>
					</Sequence>
				</Choice>
			</Sequence>
			<Sequence>
				<Symbol>:95Q::</Symbol>
				<Choice>
					<Sequence>
						<Symbol>MEOR//</Symbol>
						<Symbol Field="Originator of Message Name and Address">(?ms).{1,146}?(?=\s*^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>MERE//</Symbol>
						<Symbol Field="Recipient of Message Data Source Scheme">(?ms).{1,146}?(?=\s*^:)</Symbol>
					</Sequence>
				</Choice>
			</Sequence>
		</Choice>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>
	<Sequence Name="97a">
		<Choice>
			<Sequence>
				<Symbol>:97A::</Symbol>
				<Symbol>SAFE//</Symbol>
				<Symbol Field="Safekeeping Account Number">\w{11}|\w{8}</Symbol>
				<Symbol>\s*?(?=:)</Symbol>
			</Sequence>
			<Sequence>
				<Symbol>:97B::</Symbol>
				<Symbol>SAFE/</Symbol>
				<Optional>
					<Symbol Field="Safekeeping Data Source Scheme">\w{1,8}</Symbol>
				</Optional>
				<Symbol>/</Symbol>
				<Symbol Field="Safekeeping Account Type">\w{4}</Symbol>
				<Symbol>/</Symbol>
				<Symbol Field="Safekeeping Account Number">(?ms).{1,35}?(?=\s*^:)</Symbol>
			</Sequence>
		</Choice>
		<Symbol>\s*?(?=:)</Symbol>
	</Sequence>
	<Sequence Name='98A'>
		<Symbol>:98A::\s*</Symbol>
		<Choice>
			<Sequence>
				<Symbol>PREP//</Symbol>
				<DateTime Field='Preperation Date' Format="yyyyMMdd">\d{8}</DateTime>
			</Sequence>
			<Sequence>
				<Symbol>STAT//</Symbol>
				<DateTime Field='Statement Date' Format="yyyyMMdd">\d{8}</DateTime>
			</Sequence>
		</Choice>
		<Symbol>\s*?(?=:)</Symbol>
	</Sequence>
	<Sequence Name='98C'>
		<Symbol>:98C::\s*</Symbol>
		<Choice>
			<Sequence>
				<Symbol>PREP//</Symbol>
				<DateTime Field='Preperation Date' Format="yyyyMMddHHmmss">\d{8}\d{6}</DateTime>
			</Sequence>
			<Sequence>
				<Symbol>STAT//</Symbol>
				<DateTime Field='Statement Date' Format="yyyyMMddHHmmss">\d{8}\d{6}</DateTime>
			</Sequence>
		</Choice>
		<Symbol>\s*?(?=:)</Symbol>
	</Sequence>
	<Sequence Name='98E'>
		<!--Not Completed-->
		<Symbol>:98E::\s*</Symbol>
		<Choice>
			<Sequence>
				<Symbol>PREP//</Symbol>
				<DateTime Field='Preperation Date' Format="yyyyMMddHHmmss">\d{8}\d{6}</DateTime>
				<Optional>
					<Symbol>,\d{1,3}</Symbol>
				</Optional>
				<Optional>
					<Sequence>
						<Symbol>/</Symbol>
						<Optional>
							<Symbol>\+|-</Symbol>
						</Optional>
						<Symbol>\d{2}</Symbol>
						<Optional>
							<Symbol>\d{2}</Symbol>
						</Optional>
					</Sequence>
				</Optional>
			</Sequence>
		</Choice>
		<Symbol>\s*?(?=:)</Symbol>
	</Sequence>




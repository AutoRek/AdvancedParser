<!--
XML Parser
==========
Simple parsing of XML content including elements and attributes and comments,
but excluding namespaces and xml declarations and CDATA sections.
-->
<Rules>

	<OneOrMore>
		<Include>element</Include>
	</OneOrMore>

	<Sequence Name='element'>
		<Symbol>\s*&lt;</Symbol>
		<Choice>
			<Sequence>
				<Save>\w+</Save>
				<!-- save the symbol for the back reference -->
				<If Pattern='\s+\w'>
					<OneOrMore>
						<Include>attribute</Include>
					</OneOrMore>
				</If>
				<Choice>
					<Symbol>\s*/></Symbol>
					<Sequence>
						<Symbol>\s*></Symbol>
						<Optional>
							<Include>content</Include>
						</Optional>
						<Symbol>&lt;/</Symbol>
						<BackRef Important="true"/>
						<!-- match the saved symbol earlier -->
						<Symbol>></Symbol>
					</Sequence>
				</Choice>
			</Sequence>
			<Sequence>
				<Symbol Important="true" ErrorTemplate="Comment must end with -->">!--</Symbol>
				<Symbol>.*?(?=--)</Symbol>
				<Symbol>--&gt;</Symbol>
			</Sequence>
		</Choice>
	</Sequence>

	<OneOrMore Name='content'>
		<Choice>
			<Symbol>[^&lt;]+</Symbol>
			<Include>element</Include>
		</Choice>
	</OneOrMore>

	<Sequence Name="attribute">
		<Symbol>\s*\w+</Symbol>
		<Symbol>\s*=</Symbol>
		<Choice>
			<String Important="true"/>
			<SString Important="true"/>
		</Choice>
	</Sequence>

</Rules>

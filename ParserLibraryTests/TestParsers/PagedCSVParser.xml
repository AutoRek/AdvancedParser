<Rules>
	<!-- Example of a paged CSV directly encoded in the parser -->
	<!-- In this example, header rows are ahead of groups of rows and an end row finished off -->
	<!-- The rules have been set up with both Table/Column and Template properties -->
	<Sequence Name='root'>
		<OneOrMore>
			<Include>header</Include>
		</OneOrMore>
		<Include>end</Include>
	</Sequence>

	<Sequence Name='header' Record='H' Template='&lt;H {0} {2} {4} {6}/&gt;'>
		<Symbol Field="h1" Template="h1='{0}'">\w+</Symbol>
		<Symbol>,</Symbol>
		<SString Field="h2" Template="h2='{0}'"/>
		<Symbol>,</Symbol>
		<String Field="h3" Template="h3='{0}'" />
		<Symbol>,</Symbol>
		<Integer Field="h4" Template="h4='{0}'" />
		<Symbol>\s+</Symbol>
		<OneOrMore>
			<Include>row</Include>
		</OneOrMore>
	</Sequence>

	<Sequence Name='row' Record='R'>
		<Integer Field="r1"/>
		<Symbol>,</Symbol>
		<Symbol Field="r2">\w+</Symbol>
		<Symbol>,</Symbol>
		<Integer Field="r3"/>
		<Symbol>,</Symbol>
		<SString Field="r4"/>
		<Symbol>\s+</Symbol>
	</Sequence>

	<Sequence Name="end">
		<Symbol>\w+</Symbol>
		<Symbol>,</Symbol>
		<Symbol>\w+</Symbol>
		<Symbol>\s*</Symbol>
	</Sequence>
</Rules>
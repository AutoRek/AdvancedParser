<!--
SWIFT Shell
===========

-->
<Rules>

	<Sequence Record="Message">
		<Include>BasicHeader</Include>
		<Include>ApplicationHeader</Include>
		<Optional>
			<Include>UserHeader</Include>
		</Optional>
		<Include>TextBlock</Include>
		<Optional>
			<Include>TrailerBlock</Include>
		</Optional>
	</Sequence>

	<Sequence Name="BasicHeader">
		<Symbol>\{1:</Symbol>
		<Symbol Field="AppIdent"    >F|A|L</Symbol>
		<Symbol Field="ServiceId"   >\d{2}</Symbol>
		<Symbol Field="LTIdent"     >\w{12}</Symbol>
		<Symbol Field="SessionNbr"  >\d{4}</Symbol>
		<Symbol Field="SequenceNbr" >\d{6}</Symbol>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="ApplicationHeader">
		<Symbol>\{2:</Symbol>
		<Choice>
			<Include>InputHeader</Include>
			<Include>OutputHeader</Include>
		</Choice>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="UserHeader">
		<Symbol>\{3:</Symbol>
		<Include>CustomTags</Include>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="TextBlock">
		<Symbol>\{4:\s*</Symbol>
		<Include>MT940</Include>
		<Symbol>-\}\s*</Symbol>
	</Sequence>

	<Sequence Name="TrailerBlock">
		<Symbol>\{5:</Symbol>
		<Include>CustomTags</Include>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="InputHeader">
		<Symbol Field="InOut">I</Symbol>
		<Symbol Field="MessageType">\d{3}</Symbol>
		<Symbol Field="Receiver">\w{12}</Symbol>
		<Symbol Field="Priority">(S\d\d\d\d)|(U\d\d\d\d)|N</Symbol>
	</Sequence>

	<Sequence Name="OutputHeader">
		<Symbol>O</Symbol>
		<Symbol>\d{3}</Symbol>
		<Symbol>\d{4}</Symbol>
		<Symbol>\w{28}</Symbol>
		<Symbol>\d{6}</Symbol>
		<Symbol>\d{4}</Symbol>
		<Symbol>S|U|N</Symbol>
	</Sequence>

	<OneOrMore Name="CustomTags">
		<Sequence>
			<Symbol>\{</Symbol>
			<Symbol>\w+</Symbol>
			<Symbol>:</Symbol>
			<Symbol>.*?(?=\})</Symbol>
			<Symbol>\}\s*</Symbol>
		</Sequence>
	</OneOrMore>

	<Sequence Name="MT940">
		<Include>20</Include>
		<Choice>
			<Sequence>
				<Include>25I</Include>
				<Include>28C</Include>
				<Include>60F</Include>
				<OneOrMore>
					<Sequence Record="TransactionBlock">
						<Include>61</Include>
						<Include>86I</Include>
					</Sequence>
				</OneOrMore>
			</Sequence>
			<Sequence>
				<Include>25D</Include>
				<Include>28C</Include>
				<Include>60F</Include>
				<OneOrMore>
					<Sequence Record="TransactionBlock">
						<Include>61</Include>
						<Include>86D</Include>
					</Sequence>
				</OneOrMore>
			</Sequence>
		</Choice>
		<Include>62F</Include>
	</Sequence>

	<Sequence Name="20">
		<Symbol>:20:</Symbol>
		<Symbol Field="AccountOwner">[^:]{1,16}</Symbol>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>

	<Sequence Name="25I">
		<Symbol >:25:</Symbol>
		<Sequence>
			<Symbol Field="Country">\w{2}</Symbol>
			<Symbol Field="ControlNo">\d{2}</Symbol>
			<Symbol Field="BranchSortCode">\d{8}</Symbol>
			<Symbol Field="AccountNumber">\d{16}</Symbol>
		</Sequence>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>

	<Sequence Name="25D">
		<Symbol >:25:</Symbol>
		<Sequence>
			<Symbol Field="BankId">\w{8}</Symbol>
			<Symbol>\/</Symbol>
			<Symbol Field="AccountNumber">\d{12}</Symbol>
		</Sequence>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>

	<Sequence Name="28C">
		<Symbol>:28C:</Symbol>
		<Symbol Field="StatementNumber">\w{5}</Symbol>
		<Symbol>\/</Symbol>
		<Symbol Field="SequenceNumber">\d{3}</Symbol>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>

	<Sequence Name="60F">
		<Symbol>:60F:</Symbol>
		<Symbol Field="CreditDebit">C|D</Symbol>
		<Symbol Field="Date">\d{6}</Symbol>
		<Symbol Field="Currency">[A-Z]{3}</Symbol>
		<Symbol Field="Amount">[0-9,]{1,15}</Symbol>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>

	<Sequence Name="61">
		<Symbol>:61:</Symbol>
		<Symbol Field="Date">\d{6}</Symbol>
		<Optional>
			<Sequence>
				<Symbol Field="EntryDate">\d{4}</Symbol>
			</Sequence>
		</Optional>
		<Symbol Field="FundsCode">RC|RD|C|D</Symbol>
		<Symbol Field="Amount">[0-9,]{1,15}</Symbol>
		<Symbol Field="SwiftCode">\w{4}</Symbol>
		<Symbol Field="OwnerRef">((?!//)[A-Za-z0-9 /-?().,+ \r\n]){1,24}</Symbol>
		<!--Standards say maximum 16x, examples have 23x-->
		<Optional>
			<Sequence>
				<Symbol>//</Symbol>
				<Symbol Field="BankRef">.{1,16}</Symbol>
			</Sequence>
		</Optional>
		<Optional>
			<Sequence>
				<Symbol Field="Desc">[^:?]{1,34}</Symbol>
			</Sequence>
		</Optional>
		<Symbol>(?ms)\s*?(?=:)</Symbol>
	</Sequence>

	<Optional Name="86I">
		<Sequence>
			<Symbol>:86:</Symbol>
			<Symbol Field="Business Transaction Code">(?:\s)?[a-zA-Z0-9]{3}</Symbol>
			<OneOrMore>
				<Choice>
					<Sequence>
						<Symbol>\?\s*00</Symbol>
						<Symbol Field="Transaction Description">.*?(?=\?|^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*20</Symbol>
						<Symbol Field="Details of Payer/Beneficiary">.*?(?=\?|^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*21</Symbol>
						<Symbol Field="Details of Payer/Beneficiary 2">.*?(?=\?|^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*22</Symbol>
						<Symbol Field="Original Amount / order’s currency">.*?(?=\?|^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*23</Symbol>
						<Symbol Field="Commission (in account` s currency)">.*?(?=\?|^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*24</Symbol>
						<Symbol Field="Details of payment">.*?(?=\?|^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*25</Symbol>
						<Symbol Field="Details of payment 2">.*?(?=\?|^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*26</Symbol>
						<Symbol Field="Details of payment 3">.*?(?=\?|^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*27</Symbol>
						<Symbol Field="Details of payment 4">.*?(?=\?|^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*28</Symbol>
						<Symbol Field="Details of payment 5">.*?(?=\?|^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*29</Symbol>
						<Symbol Field="Details of payment 6">.*?(?=\?|^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*30</Symbol>
						<Symbol Field="Swift Bank Code Beneficiary">.*?(?=\?|^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*31</Symbol>
						<Symbol Field="Payers/Beneficiary Account">.*?(?=\?|^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*32</Symbol>
						<Symbol Field="Payers/Beneficiary Account">.*?(?=\?|^:)</Symbol>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*38</Symbol>
						<Symbol Field="IBAN">.*?(?=\?|^:)</Symbol>
					</Sequence>
				</Choice>
			</OneOrMore>
		</Sequence>
	</Optional>

	<Optional Name="86D">
		<Sequence>
			<Symbol>:86:</Symbol>
			<Symbol Field="Business Transaction Code">(?:\s)*[a-zA-Z0-9]{3}</Symbol>
			<OneOrMore>
				<Choice>
					<Sequence>
						<Symbol>\?\s*00</Symbol>
						<Until Field="Transaction Description">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*20</Symbol>
						<Until Field="Debit / Credit Account/Bank Code with leading zeroes">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*21</Symbol>
						<Until Field="Transaction Number">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*22</Symbol>
						<Until Field="Clients Information">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*23</Symbol>
						<Until Field="Clients Information 2">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*24</Symbol>
						<Until Field="Advice for the Beneficiary">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*25</Symbol>
						<Until Field="Advice for the Beneficiary 2">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*26</Symbol>
						<Until Field="Advice for the Beneficiary 3">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*27</Symbol>
						<Until Field="Advice for the Beneficiary 4">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*28</Symbol>
						<Until Field="Advice for the Beneficiary 5">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*29</Symbol>
						<Until Field="Advice for the Beneficiary 6">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*30</Symbol>
						<Until Field="Debit / Credit Bank Code">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*31</Symbol>
						<Until Field="Debit / Credit Account of Beneficiary">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*32</Symbol>
						<Until Field="Name of Beneficiary">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*33</Symbol>
						<Until Field="Name of Beneficiary 2">\?|^:</Until>
					</Sequence>
					<Sequence>
						<Symbol>\?\s*38</Symbol>
						<Until Field="IBAN">\?|^:</Until>
					</Sequence>
				</Choice>
			</OneOrMore>
		</Sequence>
	</Optional>

	<Sequence Name="62F">
		<Symbol>:62F:</Symbol>
		<Symbol>(?ms).*?(?=^-\})</Symbol>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>

</Rules>
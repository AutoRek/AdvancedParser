<!--
SWIFT Shell
===========

-->
<Rules>

	<Sequence Record="Message">
		<Include>BasicHeader</Include>
		<Include>ApplicationHeader</Include>
		<Optional>
			<Include>UserHeader</Include>
		</Optional>
		<Include>TextBlock</Include>
		<Optional>
			<Include>TrailerBlock</Include>
		</Optional>
	</Sequence>

	<Sequence Name="BasicHeader">
		<Symbol>\{1:</Symbol>
		<Symbol Field="AppIdent"    >F|A|L</Symbol>
		<Symbol Field="ServiceId"   >\d{2}</Symbol>
		<Symbol Field="LTIdent"     >\w{11}</Symbol>
		<Symbol Field="SessionNbr"  >\d{4}</Symbol>
		<Symbol Field="SequenceNbr" >\d{6}</Symbol>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="ApplicationHeader">
		<Symbol>\{2:</Symbol>
		<Choice>
			<Include>InputHeader</Include>
			<Include>OutputHeader</Include>
		</Choice>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="UserHeader">
		<Symbol>\{3:</Symbol>
		<Include>CustomTags</Include>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="TextBlock">
		<Symbol>\{4:\s*</Symbol>
		<Include>MT940</Include>
		<Symbol>-\}\s*</Symbol>
	</Sequence>

	<Sequence Name="TrailerBlock">
		<Symbol>\{5:</Symbol>
		<Include>CustomTags</Include>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="InputHeader">
		<Symbol Field="InOut">I</Symbol>
		<Symbol Field="MessageType">\d{3}</Symbol>
		<Symbol Field="Receiver">\w{12}</Symbol>
		<Symbol Field="Priority">(S\d\d\d\d)|(U\d\d\d\d)|N</Symbol>
	</Sequence>

	<Sequence Name="OutputHeader">
		<Symbol>O</Symbol>
		<Symbol>\d{3}</Symbol>
		<Symbol>\d{4}</Symbol>
		<Symbol>\w{28}</Symbol>
		<Symbol>\d{6}</Symbol>
		<Symbol>\d{4}</Symbol>
		<Symbol>S|U|N</Symbol>
	</Sequence>

	<OneOrMore Name="CustomTags">
		<Sequence>
			<Symbol>\{</Symbol>
			<Symbol>\w+</Symbol>
			<Symbol>:</Symbol>
			<Symbol>.*?(?=\})</Symbol>
			<Symbol>\}\s*</Symbol>
		</Sequence>
	</OneOrMore>

	<Sequence Name="MT940">
		<Include>20</Include>
		<Include>25</Include>
		<Include>28C</Include>
		<Include>60F</Include>
		<OneOrMore>
			<Sequence Record="TransactionBlock">
				<Include>61</Include>
				<Include>86</Include>
			</Sequence>
		</OneOrMore>
		<Include>62F</Include>
	</Sequence>

	<Sequence Name="20">
		<Symbol>:20:</Symbol>
		<Symbol Field="AccountOwner">.{1,16}</Symbol>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>

	<Sequence Name="25">
		<Symbol >:25:</Symbol>
		<Choice>
			<Sequence>
				<Symbol Field="Country">\w{2}</Symbol>
				<Symbol Field="ControlNo">\d{2}</Symbol>
				<Symbol Field="BranchSortCode">\d{8}</Symbol>
				<Symbol Field="AccountNumber">\d{16}</Symbol>
			</Sequence>
			<Sequence>
				<Symbol Field="BankId">\w{8}</Symbol>
				<Symbol>\/</Symbol>
				<Symbol Field="AccountNumber">\d{12}</Symbol>
			</Sequence>
		</Choice>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>

	<Sequence Name="28C">
		<Symbol>:28C:</Symbol>
		<Symbol Field="StatementNumber">\w{5}</Symbol>
		<Symbol>\/</Symbol>
		<Symbol Field="SequenceNumber">\d{3}</Symbol>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>

	<Sequence Name="60F">
		<Symbol>:60F:</Symbol>
		<Symbol Field="CreditDebit">C|D</Symbol>
		<Symbol Field="Date">\d{6}</Symbol>
		<Symbol Field="Currency">[A-Z]{3}</Symbol>
		<Symbol Field="Amount">[0-9,]{1,15}</Symbol>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>

	<Sequence Name="61">
		<Symbol>:61:</Symbol>
		<Symbol Field="Date">\d{6}</Symbol>
		<Symbol Field="EntryDate">\d{4}</Symbol>
		<Symbol Field="FundsCode">RC|RD|C|D</Symbol>
		<Symbol Field="Amount">[0-9,]{1,15}</Symbol>
		<Symbol Field="SwiftCode">\w{4}</Symbol>
		<Symbol Field="OwnerRef">[A-Za-z0-9 ]{1,16}</Symbol>
		<Symbol>//</Symbol>
		<Symbol Field="BankRef">.{1,16}</Symbol>
		<Optional>
			<Symbol Field="Desc">\r\n[A-Za-z ]{1,34}</Symbol>
		</Optional>
		<Symbol>(?ms)\s*?(?=:)</Symbol>
	</Sequence>

	<Sequence Name="86">
		<Symbol>:86:</Symbol>
		<Symbol>(?ms).*?(?=^:)</Symbol>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>

	<Sequence Name="62F">
		<Symbol>:62F:</Symbol>
		<Symbol>(?ms).*?(?=^-\})</Symbol>
		<Symbol>(?ms)\s*</Symbol>
	</Sequence>

</Rules>
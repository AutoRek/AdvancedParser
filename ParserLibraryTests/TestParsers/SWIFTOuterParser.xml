<!--
SWIFT Shell
===========

-->
<Rules>

	<Sequence>
		<Include>BasicHeader</Include>
		<Include>ApplicationHeader</Include>
		<Optional>
			<Include>UserHeader</Include>
		</Optional>
		<Include>TextBlock</Include>
		<Optional>
			<Include>CustomTags</Include>
		</Optional>
	</Sequence>

	<Sequence Name="BasicHeader">
		<Symbol>\{1:</Symbol>
		<Symbol>F|A|L</Symbol>
		<Symbol>\d{2,2}</Symbol>
		<Symbol>\w{11,11}</Symbol>
		<Symbol>\d{4,4}</Symbol>
		<Symbol>\d{6,6}</Symbol>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="ApplicationHeader">
		<Symbol>\{2:</Symbol>
		<Choice>
			<Include>InputHeader</Include>
			<Include>OutputHeader</Include>
		</Choice>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="UserHeader">
		<Symbol>\{3:</Symbol>
		<Include>CustomTags</Include>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="TextBlock">
		<Symbol>\{4:</Symbol>
		<Symbol>(?ms).*(?=-\})</Symbol>
		<Symbol>-\}</Symbol>
	</Sequence>

	<Sequence Name="TrailerBlock">
		<Symbol>\{5:</Symbol>
		<Include>CustomTags</Include>
		<Symbol>\}\s*</Symbol>
	</Sequence>

	<Sequence Name="InputHeader">
		<Symbol>I</Symbol>
		<Symbol>\d{3,3}</Symbol>
		<Symbol>\w{12,12}</Symbol>
		<Symbol>S\d\d\d\d|U\d\d\d\d|N</Symbol>
	</Sequence>

	<Sequence Name="OutputHeader">
		<Symbol>O</Symbol>
		<Symbol>\d{3,3}</Symbol>
		<Symbol>\d{4,4}</Symbol>
		<Symbol>\w{28,28}</Symbol>
		<Symbol>\d{6,6}</Symbol>
		<Symbol>\d{4,4}</Symbol>
		<Symbol>S|U|N</Symbol>
	</Sequence>

	<OneOrMore Name="CustomTags">
		<Sequence>
			<Symbol>\{</Symbol>
			<Symbol>\w+</Symbol>
			<Symbol>:</Symbol>
			<Symbol>[^}]*</Symbol>
			<Symbol>\}\s*</Symbol>
		</Sequence>
	</OneOrMore>

</Rules>
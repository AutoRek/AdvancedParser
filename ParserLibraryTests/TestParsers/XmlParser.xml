<!--
XML Parser
==========
Simple parsing of XML content including elements and attributes
excluding comments, namespaces and xml declarations.
-->
<Rules>

	<OneOrMore>
		<Include>element</Include>
	</OneOrMore>

	<Sequence Name='element'>
		<Symbol>\s*&lt;</Symbol>
		<Save>\w+</Save>	<!-- save the symbol for the back reference -->
		<If Pattern='\s+\w'>
			<OneOrMore>
				<Include>attribute</Include>
			</OneOrMore>
		</If>
		<Choice>
			<Symbol>\s*/></Symbol>
			<Sequence>
				<Symbol>\s*></Symbol>
				<Optional>
					<Include>content</Include>
				</Optional>
				<Symbol>&lt;/</Symbol>
				<BackRef/> <!-- match the saved symbol earlier -->
				<Symbol>></Symbol>
			</Sequence>
		</Choice>
	</Sequence>

	<OneOrMore Name='content'>
		<Choice>
			<Symbol>[^&lt;]+</Symbol>
			<Include>element</Include>
		</Choice>
	</OneOrMore>

	<Sequence Name="attribute">
		<Symbol>\s*\w+</Symbol>
		<Symbol>\s*=</Symbol>
		<Choice>
			<String Important="true"/>
			<SString Important="true"/>
		</Choice>
	</Sequence>

</Rules>